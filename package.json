{
  "name": "ngx-ol-library",
  "version": "0.0.0",
  "description": "A high-performance, feature-packed Angular map component library based on OpenLayers for all your mapping needs.",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "start:docs": "docgeni serve --port 4600",
    "build:docs": "docgeni build --prod",
    "build:cli": "ng build cli && npm run --prefix ./cli/ build && npm link ./dist/cli"
  },
  "private": true,
  "schematics": "./schematics/collection.json",
  "dependencies": {
    "@angular/animations": "^14.1.0",
    "@angular/cdk": "^14.1.0",
    "@angular/common": "^14.1.0",
    "@angular/compiler": "^14.1.0",
    "@angular/core": "^14.1.0",
    "@angular/forms": "^14.1.0",
    "@angular/platform-browser": "^14.1.0",
    "@angular/platform-browser-dynamic": "^14.1.0",
    "@angular/router": "^14.1.0",
    "ol": "^7.0.0",
    "rxjs": "~7.5.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.11.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^14.1.3",
    "@angular-devkit/core": "^14.2.1",
    "@angular-devkit/schematics": "^14.2.1",
    "@angular/cli": "~14.1.0",
    "@angular/compiler-cli": "^14.1.0",
    "@docgeni/cli": "^1.2.0-next.23",
    "@docgeni/template": "^1.2.0-next.23",
    "@schematics/angular": "^14.2.1",
    "@types/jasmine": "~4.0.0",
    "copyfiles": "^2.4.1",
    "jasmine-core": "~4.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "ng-packagr": "^14.1.0",
    "typescript": "~4.7.2"
  }
}
